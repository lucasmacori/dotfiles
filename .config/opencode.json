{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "datadog-kiabi": {
       "type": "remote",
       "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp",
       "headers": {
          "DD_API_KEY": "{env:DATADOG_APP_KEY_KIABI}"
       }
    },
    "figma-kiabi": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--stdio"],
      "environment": {
        "FIGMA_API_KEY": "{env:FIGMA_API_KEY}"
      },
      "enabled": true,
      "timeout": 15000
    },
    "sonarqube-cloud-kiabi": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN_KIABI}",
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG_KIABI}"
      },
      "enabled": true,
      "timeout": 15000
    }
  },
  "plugin": ["opencode-gemini-auth@latest"],
  "skills": {
    "paths": ["/Users/lucasmacori/.agents/skills"],
    "urls": []
  },
  "tools": {
    "figma-kiabi*": false,
    "sonarqube-cloud-kiabi*": false,
  },
  "permission": {
    "skill": {
      "frontend-design": "deny",
      "vercel-react-best-practices": "deny"
    }
  }
}
